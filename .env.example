# Copy this file to .env.local and fill in your own values.
# Example: NEXT_PUBLIC_API_URL=https://your-domain.tld/api/v1
NEXT_PUBLIC_API_URL=
# Example: NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Set to development for local dev; production in deploy environments.
NODE_ENV=development
# Example: NEXT_PUBLIC_SOCKET_URL=https://your-domain.tld
NEXT_PUBLIC_SOCKET_URL=
